generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  url       String?
  source    String
  notes     String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cases ResearchCase[]

  @@map("projects")
}

model ResearchCase {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  status          String    @default("created")
  generation      Int       @default(1)
  decision        String?
  decisionComment String?   @map("decision_comment")
  decidedAt       DateTime? @map("decided_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project  Project           @relation(fields: [projectId], references: [id])
  sections ResearchSection[]
  reviews  CriticReview[]
  scoring  ScoringResult?
  runs     AgentRun[]

  @@index([projectId])
  @@index([status])
  @@map("research_cases")
}

model ResearchSection {
  id           String    @id @default(uuid()) @db.Uuid
  caseId       String    @map("case_id") @db.Uuid
  sectionType  String    @map("section_type")
  iteration    Int       @default(1)
  content      Json
  sourcesCount Int       @default(0) @map("sources_count")
  status       String    @default("pending")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  case ResearchCase @relation(fields: [caseId], references: [id])

  @@unique([caseId, sectionType])
  @@index([caseId])
  @@map("research_sections")
}

model CriticReview {
  id              String   @id @default(uuid()) @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  sectionType     String   @map("section_type")
  iteration       Int      @default(1)
  evidenceQuality Int      @map("evidence_quality")
  logicQuality    Int      @map("logic_quality")
  completeness    Int
  verdict         String
  feedback        String?
  createdAt       DateTime @default(now()) @map("created_at")

  case ResearchCase @relation(fields: [caseId], references: [id])

  @@unique([caseId, sectionType, iteration])
  @@index([caseId])
  @@map("critic_reviews")
}

model ScoringResult {
  id             String   @id @default(uuid()) @db.Uuid
  caseId         String   @unique @map("case_id") @db.Uuid
  scores         Json
  totalScore     Decimal  @map("total_score") @db.Decimal(3, 2)
  recommendation String
  reasoning      String?
  weakSections   String[] @map("weak_sections")
  strongSections String[] @map("strong_sections")
  createdAt      DateTime @default(now()) @map("created_at")

  case ResearchCase @relation(fields: [caseId], references: [id])

  @@map("scoring_results")
}

model AgentRun {
  id           String    @id @default(uuid()) @db.Uuid
  caseId       String    @map("case_id") @db.Uuid
  agentType    String    @map("agent_type")
  sectionType  String?   @map("section_type")
  iteration    Int       @default(1)
  status       String
  llmModel     String?   @map("llm_model")
  inputTokens  Int?      @map("input_tokens")
  outputTokens Int?      @map("output_tokens")
  durationMs   Int?      @map("duration_ms")
  error        String?
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  case ResearchCase @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([status])
  @@map("agent_runs")
}
